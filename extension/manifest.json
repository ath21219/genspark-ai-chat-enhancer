{
  "manifest_version": 3,
  "name": "Genspark AI Chat Enhancer",
  "version": "2.0.1",
  "description": "Improve Genspark AI chat experience",
  "browser_specific_settings": {
    "gecko": {
      "id": "genspark-ai-chat-enhancer@example.org",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "menus",
    "nativeMessaging"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg",
      "48": "icons/icon-48.svg"
    },
    "default_title": "Genspark AI Chat を開く"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.genspark.ai/agents*"
      ],
      "js": [
        "content/_shared.js",
        "content/chatWidth.js",
        "content/performance.js",
        "content/toc.js",
        "content/search.js",
        "content/export.js",
        "content/shortcuts.js",
        "content/bridge.js",
        "content/main.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  }
}